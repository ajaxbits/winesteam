#!/bin/bash
# winesteam — Steam-native CLI for WineSteam
# Manages games, per-game profiles, and launches with custom Wine settings.
#
# Usage:
#   winesteam games                    List installed Steam games
#   winesteam launch <appid>           Launch a game by AppID
#   winesteam launch <name>            Launch a game by name (partial match)
#   winesteam profile <appid>          Show profile for a game
#   winesteam profile <appid> --set KEY=VALUE   Set a profile option
#   winesteam profile <appid> --reset  Reset profile to defaults
#   winesteam steam                    Launch Steam client
#   winesteam info <appid>             Show detailed game info

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Detect .app bundle context
if [[ "${SCRIPT_DIR}" == *".app/Contents/Resources"* ]]; then
    SUPPORT_DIR="${HOME}/Library/Application Support/WineSteam"
    WINE_DIR="${SUPPORT_DIR}/wine"
else
    WINE_DIR="${SCRIPT_DIR}/wine"
fi

WINE_BIN="${WINE_DIR}/bin"
DEFAULT_PREFIX="$HOME/Library/Application Support/WineSteam"
WINEPREFIX="${WINEPREFIX:-${DEFAULT_PREFIX}}"
STEAMAPPS="${WINEPREFIX}/drive_c/Program Files (x86)/Steam/steamapps"
PROFILES_DIR="${HOME}/.config/winesteam"
PROFILES_FILE="${PROFILES_DIR}/profiles.json"

# ── Colors ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── VDF Parser ────────────────────────────────────────────────────────
# Extracts a top-level key from a VDF/ACF file
vdf_get() {
    local file="$1" key="$2"
    awk -v key="\"${key}\"" '
        $1 == key {
            # Remove key and surrounding tabs/spaces, then strip quotes
            sub(/^[[:space:]]*"[^"]*"[[:space:]]*"/, "")
            sub(/"[[:space:]]*$/, "")
            print
            exit
        }
    ' "$file"
}

# ── Profiles ──────────────────────────────────────────────────────────
init_profiles() {
    mkdir -p "${PROFILES_DIR}"
    if [[ ! -f "${PROFILES_FILE}" ]]; then
        cat > "${PROFILES_FILE}" << 'ENDJSON'
{
  "default": {
    "dxvk": false,
    "env": {},
    "wine_args": "",
    "game_args": ""
  },
  "games": {}
}
ENDJSON
    fi
}

# Read a profile value using python3 (available on all macOS)
profile_get() {
    local appid="$1" key="$2"
    python3 -c "
import json, sys
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
games = data.get('games', {})
profile = games.get('${appid}', data.get('default', {}))
val = profile.get('${key}', data.get('default', {}).get('${key}', ''))
if isinstance(val, dict):
    import json as j
    print(j.dumps(val))
elif isinstance(val, bool):
    print('true' if val else 'false')
else:
    print(val)
" 2>/dev/null
}

# Set a profile value
profile_set() {
    local appid="$1" key="$2" value="$3"
    python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
if 'games' not in data:
    data['games'] = {}
if '${appid}' not in data['games']:
    data['games']['${appid}'] = dict(data.get('default', {}))
# Type coercion
val = '${value}'
if val.lower() == 'true': val = True
elif val.lower() == 'false': val = False
elif val.isdigit(): val = int(val)
data['games']['${appid}']['${key}'] = val
with open('${PROFILES_FILE}', 'w') as f:
    json.dump(data, f, indent=2)
print('Set ${key}=${value} for AppID ${appid}')
"
}

# Set an environment variable in a game's profile
profile_set_env() {
    local appid="$1" env_key="$2" env_val="$3"
    python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
if 'games' not in data:
    data['games'] = {}
if '${appid}' not in data['games']:
    data['games']['${appid}'] = dict(data.get('default', {}))
if 'env' not in data['games']['${appid}'] or not isinstance(data['games']['${appid}']['env'], dict):
    data['games']['${appid}']['env'] = {}
data['games']['${appid}']['env']['${env_key}'] = '${env_val}'
with open('${PROFILES_FILE}', 'w') as f:
    json.dump(data, f, indent=2)
print('Set env ${env_key}=${env_val} for AppID ${appid}')
"
}

# Reset a game's profile
profile_reset() {
    local appid="$1"
    python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
if 'games' in data and '${appid}' in data['games']:
    del data['games']['${appid}']
with open('${PROFILES_FILE}', 'w') as f:
    json.dump(data, f, indent=2)
print('Reset profile for AppID ${appid}')
"
}

# Get all env vars for a game as KEY=VALUE lines
profile_get_env() {
    local appid="$1"
    python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
games = data.get('games', {})
default_env = data.get('default', {}).get('env', {})
game_env = games.get('${appid}', {}).get('env', {})
merged = {**default_env, **game_env}
for k, v in merged.items():
    print(f'{k}={v}')
" 2>/dev/null
}

# ── Game Discovery ────────────────────────────────────────────────────
list_games() {
    if [[ ! -d "${STEAMAPPS}" ]]; then
        echo -e "${RED}Steam not installed yet. Run ./launch-steam.sh first.${NC}" >&2
        exit 1
    fi

    local count=0
    printf "${BOLD}%-10s %-40s %10s  %s${NC}\n" "AppID" "Name" "Size" "Status"
    printf "%-10s %-40s %10s  %s\n" "─────" "────────────────────────────" "────────" "──────"

    for manifest in "${STEAMAPPS}"/appmanifest_*.acf; do
        [[ -f "$manifest" ]] || continue

        local appid name size state installdir
        appid=$(vdf_get "$manifest" "appid")
        name=$(vdf_get "$manifest" "name")
        size=$(vdf_get "$manifest" "SizeOnDisk")
        state=$(vdf_get "$manifest" "StateFlags")
        installdir=$(vdf_get "$manifest" "installdir")

        # Skip redistributables
        [[ "$name" == *"Redistributable"* ]] && continue
        [[ "$name" == *"Proton"* ]] && continue

        # Format size
        local size_fmt
        if [[ -n "$size" ]] && [[ "$size" -gt 0 ]]; then
            if [[ "$size" -gt 1073741824 ]]; then
                size_fmt="$(( size / 1073741824 )) GB"
            elif [[ "$size" -gt 1048576 ]]; then
                size_fmt="$(( size / 1048576 )) MB"
            else
                size_fmt="$(( size / 1024 )) KB"
            fi
        else
            size_fmt="—"
        fi

        # Status
        local status_str
        if [[ "$state" == "4" ]]; then
            status_str="${GREEN}installed${NC}"
        elif [[ "$state" == "6" ]]; then
            status_str="${YELLOW}updating${NC}"
        elif [[ "$state" == "1026" ]]; then
            status_str="${YELLOW}downloading${NC}"
        else
            status_str="${DIM}state:${state}${NC}"
        fi

        # Profile indicator
        local profile_mark=""
        if [[ -f "${PROFILES_FILE}" ]]; then
            if python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    d = json.load(f)
exit(0 if '${appid}' in d.get('games', {}) else 1)
" 2>/dev/null; then
                profile_mark=" ${CYAN}[profile]${NC}"
            fi
        fi

        printf "%-10s %-40s %10s  " "$appid" "$name" "$size_fmt"
        echo -e "${status_str}${profile_mark}"
        count=$((count + 1))
    done

    echo ""
    echo -e "${DIM}${count} game(s) found. Use 'winesteam launch <appid>' to play.${NC}"
}

# Find AppID by name (partial, case-insensitive match)
find_appid_by_name() {
    local search="$1"
    local search_lower
    search_lower=$(echo "$search" | tr '[:upper:]' '[:lower:]')

    for manifest in "${STEAMAPPS}"/appmanifest_*.acf; do
        [[ -f "$manifest" ]] || continue
        local name appid
        name=$(vdf_get "$manifest" "name")
        appid=$(vdf_get "$manifest" "appid")
        local name_lower
        name_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
        if [[ "$name_lower" == *"$search_lower"* ]]; then
            echo "$appid"
            return 0
        fi
    done
    return 1
}

# ── Game Info ─────────────────────────────────────────────────────────
show_info() {
    local appid="$1"
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"

    if [[ ! -f "$manifest" ]]; then
        echo -e "${RED}Game AppID ${appid} not found.${NC}" >&2
        exit 1
    fi

    local name installdir size
    name=$(vdf_get "$manifest" "name")
    installdir=$(vdf_get "$manifest" "installdir")
    size=$(vdf_get "$manifest" "SizeOnDisk")

    echo -e "${BOLD}${name}${NC} (AppID: ${appid})"
    echo ""
    echo -e "  Install dir: ${STEAMAPPS}/common/${installdir}"

    if [[ -n "$size" ]] && [[ "$size" -gt 0 ]]; then
        echo -e "  Size on disk: $(( size / 1073741824 )) GB"
    fi

    # Check for known compatibility issues
    local has_eac=0 has_battleye=0
    local gamedir="${STEAMAPPS}/common/${installdir}"
    if [[ -d "$gamedir" ]]; then
        if find "$gamedir" -maxdepth 3 -iname "*EasyAntiCheat*" -print -quit 2>/dev/null | grep -q .; then
            has_eac=1
        fi
        if find "$gamedir" -maxdepth 3 -iname "*BattlEye*" -print -quit 2>/dev/null | grep -q .; then
            has_battleye=1
        fi
    fi

    echo ""
    echo -e "  ${BOLD}Compatibility:${NC}"
    if [[ $has_eac -eq 1 ]]; then
        echo -e "    ${RED}EasyAntiCheat detected — online multiplayer likely won't work${NC}"
    fi
    if [[ $has_battleye -eq 1 ]]; then
        echo -e "    ${RED}BattlEye detected — online multiplayer likely won't work${NC}"
    fi
    if [[ $has_eac -eq 0 ]] && [[ $has_battleye -eq 0 ]]; then
        echo -e "    ${GREEN}No known anti-cheat detected${NC}"
    fi

    # Show profile if set
    echo ""
    echo -e "  ${BOLD}Profile:${NC}"
    if [[ -f "${PROFILES_FILE}" ]] && python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    d = json.load(f)
exit(0 if '${appid}' in d.get('games', {}) else 1)
" 2>/dev/null; then
        local dxvk game_args env_vars
        dxvk=$(profile_get "$appid" "dxvk")
        game_args=$(profile_get "$appid" "game_args")
        env_vars=$(profile_get_env "$appid")
        echo -e "    DXVK: ${dxvk}"
        [[ -n "$game_args" ]] && echo -e "    Game args: ${game_args}"
        if [[ -n "$env_vars" ]]; then
            echo -e "    Environment:"
            echo "$env_vars" | while read -r line; do
                echo -e "      ${line}"
            done
        fi
    else
        echo -e "    ${DIM}Using defaults. Set with: winesteam profile ${appid} --set KEY=VALUE${NC}"
    fi
}

# ── Game Launch ───────────────────────────────────────────────────────
launch_game() {
    local appid="$1"
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"

    if [[ ! -f "$manifest" ]]; then
        echo -e "${RED}Game AppID ${appid} not found.${NC}" >&2
        exit 1
    fi

    local name
    name=$(vdf_get "$manifest" "name")
    echo -e "${BOLD}Launching ${name}${NC} (AppID: ${appid})..."

    # Apply per-game profile environment variables
    init_profiles
    local env_vars
    env_vars=$(profile_get_env "$appid")
    if [[ -n "$env_vars" ]]; then
        while IFS= read -r line; do
            export "$line"
        done <<< "$env_vars"
    fi

    # Check DXVK setting
    local dxvk
    dxvk=$(profile_get "$appid" "dxvk")
    if [[ "$dxvk" == "true" ]]; then
        export WINEDLLOVERRIDES="d3d11,d3d10core,dxgi,d3d9=n,b;${WINEDLLOVERRIDES:-}"
    fi

    # Get extra game args from profile
    local game_args
    game_args=$(profile_get "$appid" "game_args")

    # Launch via Steam's protocol (lets Steam handle the game launch)
    exec "${SCRIPT_DIR}/launch-steam.sh" -applaunch "$appid" $game_args
}

# ── Profile Management ────────────────────────────────────────────────
show_profile() {
    local appid="$1"
    shift

    init_profiles

    # Handle flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --set)
                local kv="$2"
                local key="${kv%%=*}"
                local value="${kv#*=}"
                if [[ "$key" == "env."* ]]; then
                    local env_key="${key#env.}"
                    profile_set_env "$appid" "$env_key" "$value"
                else
                    profile_set "$appid" "$key" "$value"
                fi
                shift 2
                return
                ;;
            --reset)
                profile_reset "$appid"
                shift
                return
                ;;
            *)
                shift
                ;;
        esac
    done

    # Show current profile
    local name=""
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"
    [[ -f "$manifest" ]] && name=$(vdf_get "$manifest" "name")

    echo -e "${BOLD}Profile for ${name:-AppID $appid}${NC}"
    echo ""
    python3 -c "
import json
with open('${PROFILES_FILE}') as f:
    data = json.load(f)
default = data.get('default', {})
game = data.get('games', {}).get('${appid}', None)
if game:
    print('  Custom profile:')
    print(json.dumps(game, indent=4).replace('{', '  {').replace('}', '  }'))
else:
    print('  Using defaults:')
    print(json.dumps(default, indent=4).replace('{', '  {').replace('}', '  }'))
print()
print('Set options with:')
print('  winesteam profile ${appid} --set dxvk=true')
print('  winesteam profile ${appid} --set game_args=\"-windowed\"')
print('  winesteam profile ${appid} --set env.DXVK_HUD=fps')
print('  winesteam profile ${appid} --set env.WINEDEBUG=+d3d')
"
}

# ── Usage ─────────────────────────────────────────────────────────────
usage() {
    echo -e "${BOLD}WineSteam${NC} — Steam-native Wine launcher for macOS"
    echo ""
    echo "Usage:"
    echo "  winesteam games                         List installed Steam games"
    echo "  winesteam launch <appid|name>           Launch a game"
    echo "  winesteam info <appid|name>             Show game details & compatibility"
    echo "  winesteam profile <appid> [options]     Manage per-game Wine settings"
    echo "  winesteam steam                         Launch Steam client"
    echo ""
    echo "Profile options:"
    echo "  --set KEY=VALUE    Set a profile value (dxvk, game_args, env.VAR)"
    echo "  --reset            Reset profile to defaults"
    echo ""
    echo "Examples:"
    echo "  winesteam games"
    echo "  winesteam launch 739630"
    echo "  winesteam launch phasmophobia"
    echo "  winesteam profile 739630 --set dxvk=true"
    echo "  winesteam profile 739630 --set env.DXVK_HUD=fps"
    echo "  winesteam profile 739630 --set game_args=\"-windowed\""
    echo "  winesteam info 1245620"
}

# ── Resolve AppID (number or name search) ─────────────────────────────
resolve_appid() {
    local input="$1"
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        echo "$input"
    else
        local found
        found=$(find_appid_by_name "$input") || {
            echo -e "${RED}No game matching '${input}' found.${NC}" >&2
            exit 1
        }
        echo "$found"
    fi
}

# ── Main ──────────────────────────────────────────────────────────────
init_profiles

case "${1:-}" in
    games|list|ls)
        list_games
        ;;
    launch|play|run)
        [[ -z "${2:-}" ]] && { echo "Usage: winesteam launch <appid|name>"; exit 1; }
        appid=$(resolve_appid "$2")
        launch_game "$appid"
        ;;
    info|show)
        [[ -z "${2:-}" ]] && { echo "Usage: winesteam info <appid|name>"; exit 1; }
        appid=$(resolve_appid "$2")
        show_info "$appid"
        ;;
    profile|config)
        [[ -z "${2:-}" ]] && { echo "Usage: winesteam profile <appid> [--set KEY=VALUE | --reset]"; exit 1; }
        appid=$(resolve_appid "$2")
        shift 2
        show_profile "$appid" "$@"
        ;;
    steam)
        exec "${SCRIPT_DIR}/launch-steam.sh" "${@:2}"
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}" >&2
        echo ""
        usage
        exit 1
        ;;
esac
